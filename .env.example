# PAMCA environment template. Copy to `.env` and fill in the secrets.
# `.env` is git-ignored; this file (.env.example) is committed and must stay secret-free.

# --- Supabase (server) ---------------------------------------------------------
# URL is public (also hardcoded in public/auth.js). Service-role key is SERVER-ONLY.
SUPABASE_URL=https://gqmzekycqvfxyblhjoqb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # Supabase dashboard → Project Settings → API → service_role

# --- Site ----------------------------------------------------------------------
SITE_URL=http://localhost:3000        # used for post-payment redirects; prod = https://pamca.net
PORT=3000                             # dev server port (optional, defaults to 3000)

# --- Email: Brevo transactional ------------------------------------------------
BREVO_API_KEY=                        # Brevo → SMTP & API → API Keys
CONTACT_TO_EMAIL=sales@pamca.net      # where contact-form + order notifications go
CONTACT_FROM_EMAIL=noreply@pamca.net  # verified Brevo sender
CONTACT_FROM_NAME=PAMCA

# --- reCAPTCHA (optional; skipped when blank) ----------------------------------
RECAPTCHA_SECRET=                     # Google reCAPTCHA admin console (v2 or v3)
RECAPTCHA_MIN_SCORE=0.5               # v3 only: reject scores below this

# --- Square hosted checkout ----------------------------------------------------
# While ACCESS_TOKEN/LOCATION_ID are blank, checkout degrades to "not available yet".
SQUARE_ENVIRONMENT=sandbox            # sandbox | production
SQUARE_ACCESS_TOKEN=                  # Square Developer Dashboard → app → Credentials
SQUARE_LOCATION_ID=                   # Square Dashboard → Locations (or /v2/locations)
SQUARE_CURRENCY=CAD
SQUARE_API_VERSION=2025-04-16
SQUARE_WEBHOOK_SIGNATURE_KEY=         # from the webhook subscription; blank = signature check skipped
SQUARE_WEBHOOK_URL=                   # optional; defaults to {SITE_URL}/api/checkout/webhook

# --- Canada Post (shipping rates + tracking) -----------------------------------
# Rating/tracking degrade gracefully until USER+PASSWORD+CUSTOMER_NUMBER+ORIGIN are set.
CANADA_POST_API_USER=                 # Canada Post Developer Program API key (username)
CANADA_POST_API_PASSWORD=             # Canada Post API key (password) — SERVER-ONLY secret
CANADA_POST_ENVIRONMENT=production    # production | development (ct.soa-gw test host)
CANADA_POST_CUSTOMER_NUMBER=          # your CP customer number (required by Get Rates)
CANADA_POST_ORIGIN_POSTAL_CODE=       # pharmacy ship-from postal code, e.g. M5V3L9
CANADA_POST_DEFAULT_ITEM_WEIGHT_G=500 # fallback per-unit weight (g) for products with none set
CANADA_POST_FALLBACK_SHIPPING_CENTS=0 # shipping shown when CP is unconfigured / rating fails
CANADA_POST_EXCLUDED_SERVICE_CODES=DOM.RP # hide these CP service codes at checkout (comma-separated)
